---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Cismopip">
	<div class="min-h-[70vh] flex items-center justify-center py-20">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
			<!-- Header -->
			<div class="text-center mb-12 animate-fade-in-up">
				<h1 class="text-gradient mb-4">Contactez-nous</h1>
				<p class="text-xl text-gray-600 dark:text-gray-400">
					Pour toute question ou information sur nos produits, n'hésitez pas à nous contacter.
				</p>
			</div>

			<!-- Contact form -->
			<div class="card animate-fade-in-up" style="animation-delay: 0.1s;">
				<form action="#" method="post" class="space-y-6">
					<!-- Name field -->
					<div class="space-y-2">
						<label for="name" class="block text-sm font-semibold text-gray-900 dark:text-white">
							Nom complet
						</label>
						<input
							type="text"
							id="name"
							name="name"
							required
							class="input-field"
							placeholder="Votre nom"
						/>
					</div>

					<!-- Email field -->
					<div class="space-y-2">
						<label for="email" class="block text-sm font-semibold text-gray-900 dark:text-white">
							Adresse email
						</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							class="input-field"
							placeholder="votre@email.com"
						/>
					</div>

					<!-- Message field -->
					<div class="space-y-2">
						<label for="message" class="block text-sm font-semibold text-gray-900 dark:text-white">
							Message
						</label>
						<textarea
							id="message"
							name="message"
							rows="6"
							required
							class="input-field resize-none"
							placeholder="Décrivez votre projet ou posez-nous vos questions..."
						></textarea>
					</div>

					<!-- Submit button -->
					<div class="pt-4">
						<button
							type="submit"
							class="btn btn-primary w-full sm:w-auto px-8 py-3 text-lg shadow-lg"
						>
							<span class="flex items-center space-x-2">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
								</svg>
								<span>Envoyer le message</span>
							</span>
						</button>
					</div>
				</form>
	</div>

	<!-- Additional info -->
	<div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center">
			<div class="w-12 h-12 mx-auto mb-3 bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
				</svg>
			</div>
			<h3 class="font-semibold mb-1">Email</h3>
			<p class="text-sm text-gray-600 dark:text-gray-400">contact@cismopip.fr</p>
		</div>

		<div class="text-center">
			<div class="w-12 h-12 mx-auto mb-3 bg-accent-100 dark:bg-accent-900 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
				</svg>
			</div>
			<h3 class="font-semibold mb-1">Téléphone</h3>
			<p class="text-sm text-gray-600 dark:text-gray-400">+33 1 23 45 67 89</p>
		</div>

		<div class="text-center">
			<div class="w-12 h-12 mx-auto mb-3 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
				</svg>
			</div>
			<h3 class="font-semibold mb-1">Adresse</h3>
			<p class="text-sm text-gray-600 dark:text-gray-400">Paris, France</p>
		</div>
	</div>
</BaseLayout>