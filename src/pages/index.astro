---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<style>
  html {
    scroll-behavior: smooth;
  }
</style>

<BaseLayout title="Cismopip - Sécurité Innovante">
  <!-- About Creator Section -->
   <section class="py-20 bg-white dark:bg-gray-900 overflow-hidden scroll-reveal-up fade-in">
     <div class="container mx-auto px-6">
       <!-- Section Header -->
       <div class="text-center mb-16 max-w-3xl mx-auto">
         <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gradient mb-6 fade-in-delay-100">
           À propos du créateur
         </h2>
         <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-accent-500 mx-auto rounded-full fade-in-delay-200"></div>
       </div>

       <!-- Creator Story - Narrative Layout -->
       <div class="max-w-6xl mx-auto">
         <!-- Story Intro -->
         <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
           <!-- Image Side -->
           <div class="relative scroll-reveal-left fade-in-delay-200">
             <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
               <img src="/Images/Salon.jpg" alt="Luc Tortis" class="w-full h-[400px] object-cover img-optimized transform group-hover:scale-105 transition-transform duration-700">
               <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
               <div class="absolute bottom-6 left-6 right-6 text-white">
                 <p class="text-lg font-semibold drop-shadow-lg">Luc Tortis</p>
                 <p class="text-sm opacity-90">Innovateur & Fondateur</p>
               </div>
             </div>
             <!-- Decorative element -->
             <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-primary-100 dark:bg-primary-900/30 rounded-full blur-3xl -z-10"></div>
           </div>

           <!-- Text Side -->
           <div class="scroll-reveal-right fade-in-delay-300">
             <h3 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900 dark:text-white">
               Pionnier de la sécurité biométrique
             </h3>
             <p class="text-lg text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
               Luc Tortis est un innovateur passionné qui repousse les limites de la technologie biométrique. 
               Avec une vision claire de l'avenir de la sécurité numérique, il consacre son expertise au développement 
               de solutions qui allient innovation de pointe et respect de la vie privée.
             </p>
             <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
               Son engagement : créer des technologies qui protègent sans compromettre l'expérience utilisateur.
             </p>
           </div>
         </div>

         <!-- Innovation Spotlight -->
         <div class="relative bg-gradient-to-br from-primary-50 to-accent-50 dark:from-primary-900/20 dark:to-accent-900/20 rounded-2xl p-8 md:p-12 mb-16 scroll-reveal-up fade-in-delay-400 border border-primary-100 dark:border-primary-800/30">
           <div class="absolute top-0 right-0 w-64 h-64 bg-primary-200/30 dark:bg-primary-500/10 rounded-full blur-3xl -z-10 transform translate-x-1/2 -translate-y-1/2"></div>
           <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent-200/30 dark:bg-accent-500/10 rounded-full blur-3xl -z-10 transform -translate-x-1/2 translate-y-1/2"></div>
           
           <div class="flex flex-col md:flex-row items-center gap-8">
             <div class="flex-shrink-0">
               <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-accent-500 rounded-2xl flex items-center justify-center shadow-lg">
                 <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                 </svg>
               </div>
             </div>
             <div class="flex-grow text-center md:text-left">
               <h3 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">
                 L'innovation en marche
               </h3>
               <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed mb-0">
                 Luc s'est récemment lancé dans l'innovation de son capteur à reconnaissance pénienne 
                 afin de révolutionner l'accès aux données. Cette technologie de pointe incarne sa vision 
                 d'une sécurité biométrique à la fois ultra-fiable et discrète, posant les bases d'une 
                 nouvelle ère dans la protection des actifs numériques.
               </p>
             </div>
           </div>
        </div>

         <!-- Work Image & Philosophy -->
         <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
           <!-- Text Side First on mobile -->
           <div class="order-2 lg:order-1 scroll-reveal-left fade-in-delay-200">
             <h3 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900 dark:text-white">
               Une approche unique
             </h3>
             <p class="text-lg text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
               Au travail comme dans la vie, Luc cultive une philosophie simple : la meilleure sécurité 
               est celle qui disparaît derrière l'expérience utilisateur. Il travaille main dans la main 
               avec des experts en cryptographie, en biométrie et en expérience utilisateur pour créer 
               un produit qui soit à la fois inviolable et intuitif.
             </p>
             <div class="grid grid-cols-2 gap-4 mt-8">
               <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-md border border-gray-100 dark:border-gray-700">
                 <p class="text-2xl font-bold text-primary-600 dark:text-primary-400">Innovation</p>
                 <p class="text-sm text-gray-600 dark:text-gray-400">Constante et maîtrisée</p>
               </div>
               <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-md border border-gray-100 dark:border-gray-700">
                 <p class="text-2xl font-bold text-accent-600 dark:text-accent-400">Excellence</p>
                 <p class="text-sm text-gray-600 dark:text-gray-400">Dans chaque détail</p>
               </div>
             </div>
           </div>

           <!-- Image Side -->
           <div class="order-1 lg:order-2 relative scroll-reveal-right fade-in-delay-300">
             <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
               <img src="/Images/Au travail.png" alt="Luc au travail" class="w-full h-[400px] object-cover img-optimized transform group-hover:scale-105 transition-transform duration-700">
               <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
               <div class="absolute bottom-6 left-6 right-6 text-white">
                 <p class="text-sm opacity-90">En phase de développement</p>
               </div>
             </div>
             <!-- Decorative element -->
             <div class="absolute -top-6 -left-6 w-32 h-32 bg-accent-100 dark:bg-accent-900/30 rounded-full blur-3xl -z-10"></div>
           </div>
         </div>

         <!-- Vision Statement -->
         <div class="scroll-reveal-up fade-in-delay-200">
           <div class="bg-gradient-to-r from-primary-600 to-accent-600 rounded-2xl p-8 md:p-12 text-center shadow-xl relative overflow-hidden">
             <!-- Background pattern -->
             <div class="absolute inset-0 opacity-10">
               <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                 <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                   <circle cx="1" cy="1" r="1" fill="currentColor"/>
                 </pattern>
                 <rect width="100" height="100" fill="url(#grid)"/>
               </svg>
             </div>
             <div class="relative z-10">
               <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">
                 Notre Vision
               </h3>
               <p class="text-lg text-white/90 max-w-3xl mx-auto leading-relaxed">
                 Révolutionner l'authentification avec une approche biométrique unique, 
                 alliant sécurité maximale et expérience utilisateur fluide. Nous croyons 
                 que la protection de vos données ne devrait jamais compromettre la simplicité d'utilisation.
               </p>
             </div>
           </div>
         </div>
       </div>
     </div>
   </section>

  <!-- Product Features Section (keeping existing but restyled) -->
  <section class="py-16 bg-white dark:bg-gray-900 scroll-reveal-up fade-in fade-in-delay-100">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-gradient text-3xl md:text-4xl mb-4 fade-in-delay-200">
          Pourquoi choisir Cismopip ?
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto fade-in-delay-300">
          Une sécurité inégalée pour vos actifs numériques
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow duration-300 flex flex-col items-center scroll-reveal-left fade-in-delay-400">
          <div class="w-14 h-14 bg-primary-100 dark:bg-primary-900 rounded-lg flex items-center justify-center mb-4 fade-in-delay-500">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-center fade-in-delay-600">Sécurité Maximale</h3>
          <p class="text-gray-600 dark:text-gray-400 text-center fade-in-delay-700">
            Authentification biométrique de pointe pour une protection inégalée de vos données sensibles.
          </p>
        </article>

        <article class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow duration-300 flex flex-col items-center scroll-reveal-up fade-in-delay-400">
          <div class="w-14 h-14 bg-accent-100 dark:bg-accent-900 rounded-lg flex items-center justify-center mb-4 fade-in-delay-500">
            <svg class="w-6 h-6 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-center fade-in-delay-600">Rapide & Efficace</h3>
          <p class="text-gray-600 dark:text-gray-400 text-center fade-in-delay-700">
            Accédez instantanément à vos comptes avec une simple vérification. Aucun mot de passe à retenir.
          </p>
        </article>

        <article class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow duration-300 flex flex-col items-center scroll-reveal-right fade-in-delay-400">
          <div class="w-14 h-14 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mb-4 fade-in-delay-500">
            <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 01-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-center fade-in-delay-600">Fiable & Intime</h3>
          <p class="text-gray-600 dark:text-gray-400 text-center fade-in-delay-700">
            Technologie discrète et personnelle. Votre corps est la clé, personne d'autre ne peut l'utiliser.
          </p>
        </article>
      </div>
    </div>
  </section>

   <!-- Call to Action Section -->
   <section class="py-16 bg-gradient-to-r from-primary-600 to-accent-600 scroll-reveal-up fade-in fade-in-delay-100">
     <div class="container mx-auto px-6 text-center">
       <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 fade-in-delay-200">
         Prêt à sécuriser vos données ?
       </h2>
       <p class="text-lg text-white/90 max-w-2xl mx-auto mb-8 fade-in-delay-300">
         Rejoignez des centaines d'utilisateurs satisfaits qui protègent déjà leurs actifs numériques avec Cismopip.
       </p>
       <a href="/contact" class="btn btn-light text-white px-8 py-3 hover:bg-white/20 transform hover:-translate-y-1 transition-all duration-300 fade-in-delay-400">
         Commencer l'essai gratuit
       </a>
     </div>
   </section>

   <!-- Scroll Reveal Animation Script -->
   <script is:inline>
     document.addEventListener('DOMContentLoaded', () => {
       const observerOptions = {
         root: null,
         rootMargin: '0px 0px -100px 0px',
         threshold: 0.1
       };

       const observer = new IntersectionObserver((entries) => {
         entries.forEach(entry => {
           if (entry.isIntersecting) {
             entry.target.classList.add('active');
             observer.unobserve(entry.target);
           }
         });
       }, observerOptions);

       document.querySelectorAll('.scroll-reveal, .scroll-reveal-up, .scroll-reveal-left, .scroll-reveal-right').forEach(el => {
         observer.observe(el);
       });
     });
   </script>
</BaseLayout>