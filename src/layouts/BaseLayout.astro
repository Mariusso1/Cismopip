---
import "../styles/global.css";
const { title } = Astro.props;
---
<html lang="fr" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col bg-gradient-to-b from-gray-50 to-gray-100 dark:from-dark-900 dark:to-dark-800 transition-colors duration-300 relative">
		<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-dark-800/80 border-b border-gray-200 dark:border-dark-700 shadow-sm">
			<nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
				<ul class="flex items-center justify-center space-x-1 sm:space-x-4 py-4">
					<li>
						<a href="/" class="nav-link text-sm sm:text-base">Accueil</a>
					</li>
					<li>
						<a href="/about" class="nav-link text-sm sm:text-base">À propos</a>
					</li>
					<li>
						<a href="/contact" class="nav-link text-sm sm:text-base">Contact</a>
					</li>
					<li>
						<button onclick="toggleTheme()" class="nav-link text-sm sm:text-base p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-dark-700 transition-colors" aria-label="Toggle dark mode">
							<svg id="theme-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
							</svg>
						</button>
					</li>
				</ul>
			</nav>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="backdrop-blur-md bg-white/60 dark:bg-dark-800/60 border-t border-gray-200 dark:border-dark-700 mt-auto">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
				<div class="flex flex-col md:flex-row items-center justify-between gap-4">
					<p class="text-sm text-gray-600 dark:text-gray-400 text-center md:text-left">
						© 2026 Cismopip. Tous droits réservés.
					</p>
					<div class="flex items-center space-x-4">
						<a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors" aria-label="Twitter">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path>
							</svg>
						</a>
						<a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors" aria-label="LinkedIn">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
								<circle cx="4" cy="4" r="2"></circle>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</footer>


	</body>
</html>